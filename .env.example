# LangGraph AI Service
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# AZURE_OPENAI_ENDPOINT=https://example.openai.azure.com
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# AZURE_OPENAI_MODEL_SMALL=gpt-5-nano-portal
# AZURE_OPENAI_MODEL_LARGE=gpt-5.4-portal

# Database (PostgreSQL) — same app DB as backend (for cache tables)
DB_HOST=localhost
DB_PORT=5555
DB_NAME=arcfusion
DB_USER=postgres
DB_PASSWORD=12345
DB_SCHEMA=public
DB_SSLMODE=disable

# Service
SERVICE_PORT=8001
DEBUG=true

# Include both local (8000) and production (9001) backend origins
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:9001
